# =============================================================================
# Backend template — environment variables
# =============================================================================
# Copy to .env (NEVER commit .env) before running `docker compose up`.
# =============================================================================

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (overridden by docker-compose to use the `db` service)
DATABASE_URL=postgres://app:app@localhost:5432/app

# Dev auth bypass — when true, DevAuthentication skips Auth0 JWT validation
# and DevExemptUserRateThrottle skips rate limiting. Playwright + local curl
# sessions rely on this. MUST be false in production.
DEV_AUTH_BYPASS=true

# Auth0 (only needed when DEV_AUTH_BYPASS=false)
AUTH0_DOMAIN=dev-s632khdamb3wfpqj.us.auth0.com
AUTH0_API_AUDIENCE=https://CHANGE_ME-api.namelesscompany.cc

# CORS (comma-separated origins allowed to call this API)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://CHANGE_ME.namelesscompany.cc

# Webhook HMAC shared secret — production value comes from SSM, see terraform/main.tf
EXAMPLE_WEBHOOK_SECRET=devsecret

# drf-spectacular Swagger UI title
APP_NAME=Template API
